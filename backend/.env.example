# Port for Flask app (optional, default is 5000)
PORT=5000

# Secret keys for Flask and JWT session signatures
SECRET_KEY=dev-secret-change-this
JWT_SECRET_KEY=dev-jwt-secret-change-this

# --- Stock Market APIs ---
# (Optional) Alpha Vantage API key for overview / financial statement lookups.
# If not provided, the app will fall back to local database seeded fundamentals.
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# --- Market News Streamer ---
# Get a key at: https://newsdata.io/
NEWS_API_KEY=
NEWS_API_URL=https://newsdata.io/api/1/market
NEWS_API_LANGUAGE=en
NEWS_API_SIZE=10
NEWS_API_SYMBOLS=
NEWS_STREAM_MODE=forever
STREAM_INTERVAL_SECONDS=300
MAX_NEWS_PAGES=1
ARTICLE_TIMEOUT_SECONDS=12
MAX_ARTICLE_CHARS=12000
KAFKA_BOOTSTRAP_SERVERS=redpanda:29092
KAFKA_TOPIC=atlas.market.news

# --- Artificial Intelligence (AI) LLM APIs ---
# To perform real AI stock analysis, at least one of the keys below must be provided.
# If none are provided, the app runs in Fallback/Simulated Analysis Mode.

# 1. OpenAI API Key (Model: gpt-4o-mini)
OPENAI_API_KEY=

# 2. Anthropic API Key (Model: claude-3-5-sonnet)
CLAUDE_API_KEY=

# 3. NVIDIA NIM API Key (Model: deepseek-ai/deepseek-v4-pro)
NVIDIA_API_KEY=
